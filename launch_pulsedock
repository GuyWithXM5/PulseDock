#!/bin/bash
## audplay – eww music player launcher / toggler

# Config dir is the directory containing this script
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
EWW="eww -c $DIR"
WINDOW="music-player"

# Start daemon if not running
if ! pgrep -x eww >/dev/null; then
    ${EWW} daemon
    sleep 1
fi

# Toggle: close if already open, open if not
if ${EWW} list-windows | grep -q "\*${WINDOW}"; then
    ${EWW} close "${WINDOW}"
else
    ${EWW} open "${WINDOW}"
fi
